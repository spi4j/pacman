<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="fr.pacman.soa.ide.ui.handlers.GenerateCommonSoaGeneratorHandler"
            commandId="fr.pacman.soa.ide.ui.commands.generateCommonSoaGeneratorCommand">
      </handler>
      <handler
            class="fr.pacman.soa.ide.ui.handlers.SoaGeneratorHandler"
            commandId="fr.pacman.soa.ide.ui.commands.SoaGeneratorCommand">
      </handler>
   </extension>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            locationURI="popup:org.eclipse.ui.popup.any?after=additions">
         <menu
               id="fr.pacman.soa.ide.ui.menus.generators"
               label="Generators">
            <command
                  commandId="fr.pacman.soa.ide.ui.commands.generateCommonSoaGeneratorCommand"
                  id="fr.pacman.soa.ide.ui.menus.generateCommonSoaGeneratorCommand" 
                  icon="icons/safran.png" 
                  label="Génération SOA Yvan">
               <visibleWhen
                     checkEnabled="false">
                  <with
                        variable="selection">
                     <iterate
                           ifEmpty="false"
                           operator="and">
                        <instanceof
                              value="org.eclipse.core.resources.IFile">
                        </instanceof>
                     </iterate>
                  </with>
               </visibleWhen>
            </command>
            <command
                  commandId="fr.pacman.soa.ide.ui.commands.SoaGeneratorCommand"
                  id="fr.pacman.soa.ide.ui.menus.SoaGeneratorCommand" 
                  icon="icons/safran.png" 
                  label="Génération SOA">
               <visibleWhen
                     checkEnabled="false">
                  <with
                        variable="selection">
                     <iterate
                           ifEmpty="false"
                           operator="and">
                        <and>
                           <instanceof
                                 value="org.eclipse.core.resources.IFile">
                           </instanceof>
                           <test
                                 property="org.eclipse.core.resources.extension"
                                 value="soa">
                           </test>
                        </and>
                     </iterate>
                  </with>
               </visibleWhen>
            </command>
         </menu>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <category
            id="fr.pacman.soa.ide.ui.commands.generatorsCategory"
            name="Generators">
      </category>
      <command
            categoryId="fr.pacman.soa.ide.ui.commands.generatorsCategory"
            id="fr.pacman.soa.ide.ui.commands.generateCommonSoaGeneratorCommand"
            name="fr::pacman::soa::generateCommonSoa">
      </command>
      <command
            categoryId="fr.pacman.soa.ide.ui.commands.generatorsCategory"
            id="fr.pacman.soa.ide.ui.commands.SoaGeneratorCommand"
            name="fr::pacman::soa::generateServerSoa">
      </command>
   </extension>

</plugin>

